{
  "name": "resumeai-server",
  "version": "1.0.0",
  "private": true,
  "description": "ResumeAI backend — Express + TypeScript + Prisma + Claude",
  "main": "dist/server/src/index.js",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
